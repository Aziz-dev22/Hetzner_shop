# ==========================================================
# Hetzner Shop
# Environment Example
# ==========================================================


# Application

APP_NAME=Hetzner Shop

APP_ENV=production

APP_DEBUG=False

APP_URL=http://localhost:8000



# Security

SECRET_KEY=change_this_secret_key

JWT_SECRET_KEY=change_this_jwt_secret



# Database PostgreSQL

DATABASE_ENGINE=postgresql

DATABASE_HOST=postgres

DATABASE_PORT=5432

DATABASE_NAME=hetzner_shop

DATABASE_USER=hetzner

DATABASE_PASSWORD=change_this_password



# Redis

REDIS_HOST=redis

REDIS_PORT=6379



# Hetzner Cloud API

HETZNER_API_TOKEN=your_hetzner_api_token_here



# Telegram Notification (Optional)

TELEGRAM_NOTIFICATION_TOKEN=

TELEGRAM_NOTIFICATION_CHAT_ID=



# SMTP Email (Optional)

SMTP_HOST=

SMTP_PORT=587

SMTP_USERNAME=

SMTP_PASSWORD=

SMTP_FROM_EMAIL=



# Server

SERVER_TIMEZONE=UTC
