###############################################################################
# Hetzner Shop
# Environment Configuration
###############################################################################

###############################################################################
# Application
###############################################################################

APP_NAME="Hetzner Shop"

APP_VERSION="1.0.0"

APP_CHANNEL="stable"

APP_RELEASE="Genesis"

ENVIRONMENT="production"

DEBUG=false

TIMEZONE="UTC"

LANGUAGE="fa"

###############################################################################
# Telegram
###############################################################################

BOT_TOKEN=""

ADMIN_IDS=""

###############################################################################
# Web Panel
###############################################################################

WEB_HOST="0.0.0.0"

WEB_PORT="8080"

WEB_USERNAME="admin"

WEB_PASSWORD=""

WEB_SESSION_EXPIRE=86400

###############################################################################
# Database
###############################################################################

DATABASE_ENGINE="sqlite"

DATABASE_URL="sqlite+aiosqlite:///data/database.db"

###############################################################################
# Security
###############################################################################

SECRET_KEY=""

JWT_SECRET_KEY=""

JWT_ALGORITHM="HS256"

JWT_EXPIRE_HOURS=24

ENCRYPTION_KEY=""

###############################################################################
# Logging
###############################################################################

LOG_LEVEL="INFO"

LOG_TO_FILE=true

LOG_DIRECTORY="logs"

###############################################################################
# Backup
###############################################################################

AUTO_BACKUP=true

BACKUP_DIRECTORY="backups"

BACKUP_KEEP_DAYS=30

###############################################################################
# Uploads
###############################################################################

UPLOAD_DIRECTORY="data/uploads"

MAX_UPLOAD_SIZE_MB=50

###############################################################################
# Cache
###############################################################################

ENABLE_REDIS=false

REDIS_URL="redis://127.0.0.1:6379"

###############################################################################
# Scheduler
###############################################################################

ENABLE_SCHEDULER=true

###############################################################################
# Providers
###############################################################################

DEFAULT_PROVIDER="hetzner"

###############################################################################
# Hetzner
###############################################################################
# API Token ها در این فایل ذخیره نمی‌شوند.
# همه Token ها داخل دیتابیس به صورت رمزنگاری شده نگهداری خواهند شد.
###############################################################################

###############################################################################
# SSL
###############################################################################

ENABLE_SSL=false

SSL_CERT=""

SSL_KEY=""

###############################################################################
# Nginx
###############################################################################

ENABLE_NGINX=false

###############################################################################
# Installer
###############################################################################

INSTALL_DATE=""

BUILD_NUMBER=""

###############################################################################
# Future Providers
###############################################################################

ENABLE_LEASEWEB=false

ENABLE_WORLDSTREAM=false

ENABLE_OVH=false

ENABLE_LINODE=false

ENABLE_DIGITALOCEAN=false

ENABLE_VULTR=false

ENABLE_GCORE=false
