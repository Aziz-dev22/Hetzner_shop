# ==========================================================
# Hetzner Shop
# Environment Configuration Example
# Copy this file to .env and fill real values
# ==========================================================


# -------------------------
# Application
# -------------------------

APP_NAME=Hetzner-Shop

APP_ENV=production

APP_DEBUG=false

APP_URL=https://example.com



# -------------------------
# Security
# -------------------------

SECRET_KEY=change_this_secret_key

JWT_SECRET_KEY=change_this_jwt_secret



# -------------------------
# Database
# -------------------------

DATABASE_ENGINE=postgresql

DATABASE_HOST=127.0.0.1

DATABASE_PORT=5432

DATABASE_NAME=hetzner_shop

DATABASE_USER=hetzner

DATABASE_PASSWORD=change_database_password



# -------------------------
# Redis / Queue
# -------------------------

QUEUE_DRIVER=redis

REDIS_HOST=127.0.0.1

REDIS_PORT=6379

WORKER_COUNT=2



# -------------------------
# Hetzner API
# -------------------------

HETZNER_API_TOKEN=your_hetzner_api_token



# -------------------------
# Telegram Notification
# -------------------------

TELEGRAM_NOTIFICATION_TOKEN=

TELEGRAM_NOTIFICATION_CHAT_ID=



# -------------------------
# Email / SMTP
# -------------------------

SMTP_HOST=smtp.example.com

SMTP_PORT=587

SMTP_USERNAME=

SMTP_PASSWORD=

SMTP_FROM_EMAIL=



# -------------------------
# Server
# -------------------------

SERVER_TIMEZONE=UTC

SERVER_LOCALE=en_US.UTF-8



# -------------------------
# Logging
# -------------------------

LOG_LEVEL=INFO

LOG_PATH=logs/app.log
